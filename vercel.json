{
  "rewrites": [
    { "source": "/", "destination": "/freeofugly_ask.html" },
    { "source": "/dashboard", "destination": "/FreeOfUgly_Dashboard.html" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "functions": {
    "api/generate-slides.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/sync-instagram",
      "schedule": "0 14 * * *"
    }
  ]
}
